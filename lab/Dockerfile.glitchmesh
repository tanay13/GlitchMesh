FROM golang:1.24-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /glitchmesh ./cmd/glitchmesh

FROM alpine:3.20

RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /glitchmesh .

EXPOSE 9000
ENTRYPOINT ["./glitchmesh"]
CMD ["start", "server"]
